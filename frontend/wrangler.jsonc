{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tutorai",
  "compatibility_date": "2026-03-04",
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "tutorbook.me/*",
      "zone_name": "tutorbook.me"
    },
    {
      "pattern": "www.tutorbook.me/*",
      "zone_name": "tutorbook.me"
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
