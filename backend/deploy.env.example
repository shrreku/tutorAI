# Copy this file to backend/deploy.env on the server.
# Do not commit the real deploy.env file.

# Core runtime
# Use the Neon direct connection string here, not the pooled PgBouncer URL.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DB?ssl=require
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# Auth / admin
AUTH_ENABLED=true
AUTH_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
AUTH_ENFORCE_STRONG_SECRET=true
AUTH_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EXTERNAL_ID=you@example.com
ADMIN_BOOTSTRAP_EMAIL=you@example.com
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-strong-admin-password
ADMIN_BOOTSTRAP_DISPLAY_NAME=StudyAgent Admin
CORS_ALLOWED_ORIGINS=https://tutorbook.me,https://www.tutorbook.me
APP_BASE_URL=https://tutorbook.me

# Abuse controls
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
AUTH_RATE_LIMIT_REQUESTS_PER_MINUTE=20

# LLM / BYOK
BYOK_ENABLED=true
BYOK_REQUIRE_HTTPS=true
BYOK_ALLOW_PRIVATE_BASE_URLS=false
ASYNC_BYOK_ESCROW_ENABLED=false
ALLOW_LLM_MODEL_OVERRIDE_HEADERS=false
LLM_API_KEY=replace-with-platform-llm-key
LLM_API_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash-lite
LLM_MODEL_ONTOLOGY=google/gemini-3-flash-preview
LLM_MODEL_ENRICHMENT=google/gemini-2.5-flash-lite
LLM_MODEL_CURRICULUM=google/gemini-3-flash-preview
LLM_MODEL_TUTORING=google/gemini-3-flash-preview
LLM_MODEL_EVALUATION=google/gemini-3-flash-preview
LLM_COST_TRACKING_ENABLED=true

# Queue / worker
INGESTION_QUEUE_ENABLED=true
INGESTION_WORKER_CONCURRENCY=2
INGESTION_WORKER_MAX_RETRIES=3
INGESTION_PREWARM_ENABLED=true
EMBEDDING_PREWARM_ENABLED=true

# Embeddings / ingestion
EMBEDDING_PROVIDER=openrouter
EMBEDDING_MODEL_ID=google/gemini-embedding-001
EMBEDDING_DIMENSION=1536
EMBEDDING_API_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=replace-with-embedding-api-key
LLAMAPARSE_API_KEY=replace-with-llamaparse-api-key
LLAMAPARSE_API_BASE_URL=https://api.cloud.llamaindex.ai
LLAMAPARSE_TIER=agentic_plus
LLAMAPARSE_VERSION=latest
# Direct Gemini alternative:
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL_ID=gemini-embedding-001
# EMBEDDING_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# EMBEDDING_API_KEY=replace-with-gemini-api-key
INGESTION_DOCLING_PROFILE=balanced
INGESTION_DOCLING_DEVICE=auto
INGESTION_DOCLING_NUM_THREADS=4
INGESTION_DOCLING_OCR_ENGINE=auto
INGESTION_DOCLING_OCR_LANGS=eng
INGESTION_DOCLING_TABLE_MODE=accurate
INGESTION_DOCLING_TABLE_CELL_MATCHING=true
INGESTION_DOCLING_TIMEOUT_S=0

# Storage (Cloudflare R2 recommended)
STORAGE_BACKEND=s3
STORAGE_LOCAL_DIR=/app/storage
S3_BUCKET_NAME=studyagent-prod
S3_REGION=auto
MINIO_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
MINIO_ACCESS_KEY=replace-me
MINIO_SECRET_KEY=replace-me

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACE_MODE=simple

# Sentry (PROD-013)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# OpenTelemetry (PROD-013)
OTEL_ENABLED=false
# OTEL_EXPORTER_ENDPOINT=
# OTEL_SERVICE_NAME=studyagent-api

# Analytics – PostHog (PROD-014)
POSTHOG_ENABLED=false
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://us.i.posthog.com

# Public app / alpha access
ALPHA_ACCESS_ENABLED=true
ALPHA_PROMO_CODES=
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@tutorbook.me

# Product limits / features
CREDITS_ENABLED=true
CREDITS_SIGNUP_GRANT=0
CREDITS_DEFAULT_MONTHLY_GRANT=0
MODEL_SELECTION_ENABLED=true
MODEL_SELECTION_FRONTEND_ENABLED=true
OPERATION_METERING_ENABLED=true
INGESTION_ESTIMATION_V2_ENABLED=true
MODEL_TASK_HEALTH_ROUTING_ENABLED=true
ADMIN_MODEL_CONTROL_ENABLED=true
ARTIFACT_MODEL_SELECTION_ENABLED=true
SESSION_PREPARATION_METERING_ENABLED=true
UPLOAD_MAX_FILE_SIZE_MB=25
UPLOAD_ALLOWED_EXTENSIONS=.pdf,.docx,.pptx,.md,.html,.txt,.csv
UPLOAD_MAX_FILES_PER_USER_PER_DAY=5
INGESTION_MAX_CONCURRENT_JOBS=2
FEATURE_UPLOADS_ENABLED=true
FEATURE_ENRICHMENT_ENABLED=true
FEATURE_OCR_ENABLED=true
FEATURE_NOTEBOOKS_ENABLED=true

# Workspace overhaul flags (PROD-014)
FF_WORKSPACE_V2_ENABLED=true
FF_ACTIVE_LEARNING_ENABLED=true
FF_ARTIFACT_GENERATION_ENABLED=true

# Optional services
NEO4J_ENABLED=false
# NEO4J_URI=
# NEO4J_USER=
# NEO4J_PASSWORD=

# If you enable async BYOK escrow, also configure one of:
# ASYNC_BYOK_ESCROW_BACKEND=local
# ASYNC_BYOK_LOCAL_KEK=<urlsafe-base64-32-byte-key>
#
# or
#
# ASYNC_BYOK_ESCROW_BACKEND=vault_transit
# ASYNC_BYOK_VAULT_URL=
# ASYNC_BYOK_VAULT_TOKEN=
# ASYNC_BYOK_VAULT_TRANSIT_KEY_NAME=studyagent-async-byok
