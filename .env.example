# =============================================================================
# StudyAgent Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (Required)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/studyagent
# -----------------------------------------------------------------------------
# LLM Configuration (Required)
# -----------------------------------------------------------------------------
LLM_API_KEY=your-api-key-here
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Token limits
LLM_MAX_TOKENS_PER_CALL=4096
LLM_MAX_TOKENS_PER_TURN=8192
LLM_MAX_TOKENS_PER_SESSION=100000
LLM_RATE_LIMIT_RPM=60
LLM_COST_TRACKING_ENABLED=true

# Per-task model overrides (leave empty to use LLM_MODEL as fallback)
# LLM_MODEL_ONTOLOGY=gpt-4.1          # Full-content ontology extraction
# LLM_MODEL_ENRICHMENT=gpt-4.1-mini   # Per-chunk/batch enrichment
# LLM_MODEL_TUTORING=gpt-4o-mini       # Interactive tutoring (latency-sensitive)
# LLM_MODEL_EVALUATION=gpt-4.1-mini    # Evaluator + safety critic
# LLM_MODEL_CURRICULUM=gpt-4.1-mini    # Curriculum planning

# Per-task token limits
# ONTOLOGY_MAX_INPUT_TOKENS=100000
# ONTOLOGY_MAX_OUTPUT_TOKENS=16384
# ENRICHMENT_MAX_INPUT_TOKENS=30000
# ENRICHMENT_MAX_OUTPUT_TOKENS=4096
# ENRICHMENT_MAX_CHUNKS_PER_BATCH=8

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------
EMBEDDING_MODEL_ID=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
# Optional: Use API instead of local embeddings
# EMBEDDING_API_BASE_URL=
# EMBEDDING_API_KEY=

# -----------------------------------------------------------------------------
# Authentication (Optional - disabled by default for local dev)
# -----------------------------------------------------------------------------
AUTH_ENABLED=false
AUTH_SECRET_KEY=your-secret-key-change-in-production
AUTH_ALGORITHM=HS256
AUTH_TOKEN_EXPIRE_MINUTES=1440

# -----------------------------------------------------------------------------
# Rate Limiting (Optional)
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# -----------------------------------------------------------------------------
# Storage Configuration (Optional)
# -----------------------------------------------------------------------------
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./storage

# S3/MinIO Configuration (if STORAGE_BACKEND=s3)
# S3_BUCKET_NAME=studyagent
# S3_REGION=us-east-1
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin

# -----------------------------------------------------------------------------
# Optional Services
# -----------------------------------------------------------------------------
# Redis
# REDIS_URL=redis://localhost:6379/0

# Neo4j
# NEO4J_ENABLED=false
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password

# -----------------------------------------------------------------------------
# Observability (Optional)
# -----------------------------------------------------------------------------
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
POLICY_MODE=llm_only
LLM_RERANKER_ENABLED=false
ADAPTIVE_DELEGATION_ENABLED=true
TUTOR_SERVICE_V2_ENABLED=true

# -----------------------------------------------------------------------------
# Hosting / Production Settings
# -----------------------------------------------------------------------------

# BYOK (Bring Your Own Key) — when true, users must supply their own LLM keys
BYOK_ENABLED=false
# Security defaults for BYOK base URLs
BYOK_ALLOW_PRIVATE_BASE_URLS=false
BYOK_REQUIRE_HTTPS=true

# Public auth endpoint abuse controls
AUTH_RATE_LIMIT_REQUESTS_PER_MINUTE=20

# Upload quotas
UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_ALLOWED_EXTENSIONS=.pdf,.docx,.pptx,.md,.html,.txt,.csv
UPLOAD_MAX_FILES_PER_USER_PER_DAY=10
INGESTION_MAX_CONCURRENT_JOBS=3

# Queue / Worker (required for production ingestion)
# REDIS_URL must be set for durable queue mode
INGESTION_QUEUE_ENABLED=false

# Kill switches — disable expensive features in emergencies
FEATURE_UPLOADS_ENABLED=true
FEATURE_ENRICHMENT_ENABLED=true
FEATURE_OCR_ENABLED=true

# Credits system (first implementation slice)
CREDITS_ENABLED=false
CREDITS_DEFAULT_MONTHLY_GRANT=100000
CREDITS_INPUT_TOKEN_MULTIPLIER=1.0
CREDITS_OUTPUT_TOKEN_MULTIPLIER=1.5
CREDITS_OCR_SURCHARGE=250
CREDITS_WEB_SEARCH_SURCHARGE=100

# Quota / abuse controls
CREDITS_DAILY_LIMIT=20000
CREDITS_MONTHLY_LIMIT=100000
CREDITS_SOFT_LIMIT_PCT=0.8
CREDITS_TURN_MAX_COST=5000
